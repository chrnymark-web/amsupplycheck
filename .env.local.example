# Copy to .env.local and fill in. Same values as the existing root .env
# (VITE_SUPABASE_URL → NEXT_PUBLIC_SUPABASE_URL,
#  VITE_SUPABASE_PUBLISHABLE_KEY → NEXT_PUBLIC_SUPABASE_ANON_KEY).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# GTM container ID — currently GTM-M8LFXBKR in the live site.
NEXT_PUBLIC_GTM_ID=GTM-M8LFXBKR

# Phase 8 will add ANTHROPIC_API_KEY, OPENAI_API_KEY, PERPLEXITY_API_KEY here.
